{
  "name": "tmux-web",
  "version": "1.0.0",
  "description": "Web-based tmux client with AI command generation — access tmux sessions from iPhone/iPad/desktop browser",
  "license": "MIT",
  "author": "Wu Di",
  "repository": {
    "type": "git",
    "url": "https://github.com/includewudi/opencode-tmuxweb.git"
  },
  "bugs": "https://github.com/includewudi/opencode-tmuxweb/issues",
  "homepage": "https://github.com/includewudi/opencode-tmuxweb#readme",
  "main": "server/index.js",
  "engines": {
    "node": ">=18.0.0 <23.0.0",
    "npm": ">=8.0.0"
  },
  "scripts": {
    "start": "node server/index.js",
    "dev": "node server/index.js",
    "frontend": "cd web && npm run dev",
    "backend": "node server/index.js",
    "install:all": "npm install && cd web && npm install"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "multer": "^2.1.1",
    "mysql2": "^3.16.3",
    "node-pty": "^1.0.0",
    "ws": "^8.16.0"
  }
